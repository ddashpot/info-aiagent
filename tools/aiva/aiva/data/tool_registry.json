{
  "meta": {
    "name": "AIセキュリティ ツール・レジストリ",
    "version": "1.0.0",
    "note": "garak / PyRIT など外部セキュリティツールを、共有カタログの脆弱性(surface×failure_mode)へマッピングする。aiva coverage が『どのセルをどのツールが埋めるか／空白はどこか』を算定する。kind は検査の種類。covers はカタログ脆弱性ID。adapter があれば aiva から実行・正規化できる。defenses は検査ではなくコントロール実装(実装基盤)。"
  },
  "kinds": [
    { "id": "llm-redteam", "name": "LLMレッドチーム/スキャナ" },
    { "id": "eval", "name": "評価/ベンチ" },
    { "id": "sast", "name": "静的解析(コード)" },
    { "id": "dast", "name": "動的解析(Web/API)" },
    { "id": "sca", "name": "依存/SBOM" },
    { "id": "secrets", "name": "シークレットスキャン" },
    { "id": "mcp", "name": "MCP/ツール接続検査" },
    { "id": "agentic", "name": "エージェント構成検査" },
    { "id": "adversarial-ml", "name": "敵対的ML" },
    { "id": "recon", "name": "ネットワーク偵察" },
    { "id": "iac", "name": "IaC/コンテナ/K8s姿勢" },
    { "id": "cloud", "name": "クラウド姿勢" }
  ],
